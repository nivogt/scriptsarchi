console.show();

var modelName = "Dev - Resource Management - MDS"

// Create a new model and set it as the current model
$.model.create(modelName).setAsCurrent();
console.log("Created model: " + model.name);

// Find the "Business" folder using a selector
var viewFolder = $("folder.Views").first();
console.log("Found folder: " + viewFolder);

/*
* Move To Cloud
*/

var moveToCloudFolder = viewFolder.createFolder("Move To Cloud");
console.log("Created folder: " + moveToCloudFolder);

/* 
* TOGAF 
*
*/

var togafFolder = viewFolder.createFolder("TOGAF");
console.log("Created folder: " + togafFolder);

var togafDiagramsFolder = togafFolder.createFolder("Diagrams");
console.log("Created folder: " + togafDiagramsFolder);

var togafDiagramList = [
 "Value Chain Diagram",
