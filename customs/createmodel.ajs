]

for (var elementOfTogafDiagramList in togafDiagramList) {
    var diagramView = model.createArchimateView(togafDiagramList[elementOfTogafDiagramList],togafDiagramsFolder);
    console.log("Created view - ", togafDiagramList[elementOfTogafDiagramList]);
}

var togafDeliverablesFolder = togafFolder.createFolder("Deliverables");
console.log("Created folder: " + togafDeliverablesFolder);

